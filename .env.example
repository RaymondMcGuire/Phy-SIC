# Copy this file to .env and edit paths for your machine.
#
# WSL path examples:
#   D:\SMPL-project\Phy-SIC\data    -> /mnt/d/SMPL-project/Phy-SIC/data
#   D:\SMPL-project\Phy-SIC\images  -> /mnt/d/SMPL-project/Phy-SIC/images
#   D:\SMPL-project\Phy-SIC\outputs -> /mnt/d/SMPL-project/Phy-SIC/outputs
#
# If you run docker compose from the same checkout where data/images/outputs live,
# the relative defaults below are enough. If your data was downloaded from Windows
# into D:\SMPL-project\Phy-SIC while this checkout lives in ~/project/Phy-SIC,
# use the /mnt/d/... paths instead.

PHYSIC_DATA_DIR=./data
PHYSIC_IMAGES_DIR=./images
PHYSIC_OUTPUTS_DIR=./outputs

# Hugging Face token used only by fetch_hf_data.bat during Windows pre-download.
# Docker runtime is forced offline and does not receive this token.
# FLUX.1-dev is gated; this token must belong to an account that accepted access.
# Keep the token local in .env; do not commit it.
HF_TOKEN=

# Docker runtime is intentionally offline for Hugging Face. These are documented
# here for visibility; compose.yaml pins them to 1.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
DIFFUSERS_OFFLINE=1

# CUDA / build settings.
# RTX 5090 / sm_120: 12.0
# RTX 30xx: 8.6
TORCH_CUDA_ARCH_LIST=12.0
PHYSIC_CUDA_IMAGE=nvidia/cuda:12.8.0-devel-ubuntu22.04

# Runtime CUDA settings. Use cuda:1 to put OmniEraser/FLUX on your second GPU.
# If FLUX still runs out of VRAM, change PHYSIC_OMNI_OFFLOAD to sequential.
PHYSIC_OMNI_DEVICE=cuda
PHYSIC_OMNI_OFFLOAD=model
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Lower these if Docker build stalls or the machine runs out of memory.
PHYSIC_BUILD_JOBS=2
UV_CONCURRENT_DOWNLOADS=2
UV_CONCURRENT_BUILDS=1
UV_CONCURRENT_INSTALLS=2

# Runtime container limits.
PHYSIC_CPUS=8
PHYSIC_MEM_LIMIT=32g
